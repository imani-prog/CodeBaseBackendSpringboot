  "dropoffCountry": "Kenya",
  "dropoffLatitude": -1.301052,
  "dropoffLongitude": 36.808251
}

### Dispatch: Get all
GET {{baseUrl}}/api/assist
Authorization: Bearer {{jwtToken}}

### Dispatch: Get by id
GET {{baseUrl}}/api/assist/{{dispatchId}}
Authorization: Bearer {{jwtToken}}

### Dispatch: Update
PUT {{baseUrl}}/api/assist/{{dispatchId}}
Authorization: Bearer {{jwtToken}}
Content-Type: application/json

{
  "patientId": 13,
  "callerName": "Esther Njeri",
  "callerPhone": "+254701234567",
  "incidentType": "Road Traffic Accident",
  "notes": "Patient stable but requires urgent trauma care",
  "pickupLatitude": -1.292066,
  "pickupLongitude": 36.821945,
  "pickupAddressLine1": "Moi Avenue",
  "pickupAddressLine2": "Near Nation Centre",
  "pickupCity": "Nairobi",
  "pickupState": "Nairobi County",
  "pickupPostalCode": "00100",
  "pickupCountry": "Kenya",
  "hospitalId": 1,
